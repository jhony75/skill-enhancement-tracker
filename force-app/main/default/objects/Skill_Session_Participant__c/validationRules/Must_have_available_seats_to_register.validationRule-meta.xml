<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Must_have_available_seats_to_register</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status__c, &quot;Confirmed&quot;),
  Skill_Session__r.Seats_Open__c &lt;= 0
)</errorConditionFormula>
    <errorMessage>This session has no open seats available.</errorMessage>
</ValidationRule>
